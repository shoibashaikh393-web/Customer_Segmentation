import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans

df = pd.read_csv("meesho_order_data_2025_50rows.csv")

df.head()

df.info()

df.describe()

#df.columns()

df.isnull().sum()

df.fillna(0, inplace=True)

df.drop_duplicates(inplace=True)



df["Order_Date"] = pd.to_datetime(df["Order_Date"], dayfirst=True)

customer_df = df.groupby("Customer_Name").agg({

"Order_ID":"count",

"Quantity":"sum",

"Sale_Price":"sum",

"Discount_Percent":"mean"

}).reset_index()

customer_df.columns=[

"Customer",

"TotalOrders",

"TotalQuantity",

"TotalSpent",

"AverageDiscount"

]

customer_df["AverageOrderValue"] = customer_df["TotalSpent"] / customer_df["TotalOrders"]

X = customer_df[[

"TotalOrders",

"TotalQuantity",

"TotalSpent",

"AverageDiscount",

"AverageOrderValue"

]]

scaler = StandardScaler()

X_scaled = scaler.fit_transform(X)

wcss=[]

for i in range(1,11):

    model=KMeans(n_clusters=i,random_state=42)

    model.fit(X_scaled)

    wcss.append(model.inertia_)

plt.plot(range(1,11),wcss,marker="o")

plt.xlabel("Clusters")

plt.ylabel("WCSS")

plt.title("Elbow Method")

plt.show()

kmeans = KMeans(

n_clusters=4,

random_state=42

)

customer_df["Cluster"] = kmeans.fit_predict(X_scaled)

customer_df.groupby("Cluster").mean(numeric_only=True)

customer_df.to_csv(

"CustomerSegmented.csv",

index=False

)

